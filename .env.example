# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit your real credentials.

# --- Owner / admin login (seeded into the DB on first run) ---
OWNER_EMAIL=you@example.com
OWNER_USERNAME=Owner
OWNER_PASSWORD=change-this-to-something-strong

# 4-digit PIN used for extra admin confirmation prompts in the UI
ADMIN_PIN=0000

# --- Ground station host (e.g. the Raspberry Pi running your SDR capture) ---
PI_IP=192.168.1.100
PI_USER=pi

# --- Public support contact shown in the site footer ---
CONTACT_EMAIL=you@example.com
